# japan-gov-mcp 環境変数
# コピーして .env として使用: cp .env.example .env

# ─── 必須（Tier 1: 統計基盤）───
# e-Stat API アプリケーションID
# 取得: https://www.e-stat.go.jp/api/api-dev/how_to_use
ESTAT_APP_ID=

# RESAS API キー
# 取得: https://opendata.resas-portal.go.jp/
RESAS_API_KEY=

# ─── 推奨（Tier 2: 法人・金融）───
# 法人番号 API アプリケーションID
# 取得: https://www.houjin-bangou.nta.go.jp/webapi/
HOUJIN_APP_ID=

# gBizINFO API トークン
# 取得: https://info.gbiz.go.jp/hojin/api
GBIZ_TOKEN=

# EDINET API Subscription Key
# 取得: https://disclosure2.edinet-fsa.go.jp/
EDINET_API_KEY=

# 特許情報API
# EPO OPS (欧州特許庁) — 日本特許含む: https://developers.epo.org/
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=
# Lens.org — 非商用無料: https://www.lens.org/lens/user/apikey
LENS_API_TOKEN=

# ─── オプション ───
# ハローワーク求人API キー
HELLOWORK_API_KEY=

# 不動産情報ライブラリ API キー
# 取得: https://www.reinfolib.mlit.go.jp/ （アカウント登録→API利用申請）
REALESTATE_API_KEY=

# 国交省データプラットフォーム API キー
# 取得: https://www.mlit-data.jp/ （アカウント登録→APIキー発行）
MLIT_DPF_API_KEY=

# 海しる（MSIL）API キー
# 取得: https://www.msil.go.jp/ （利用登録申請→審査→APIキー発行）
# 注意: 審査に数日かかる場合あり。海洋空間情報のGeoJSONデータ取得に使用
MSIL_API_KEY=

# ODPT 公共交通オープンデータ API キー
# 取得: https://developer.odpt.org/ （デベロッパーサイトでアカウント登録→APIキー発行）
# 対応データ: 鉄道時刻表（東京メトロ等）、バス時刻表（都営バス等）
ODPT_API_KEY=

# ─── APIキー不要で利用可能（28 API）───
# 統計ダッシュボード, 法令API, データカタログ(data.go.jp), 海外安全情報,
# 気象庁(天気予報/週間/台風/地震/津波/AMEDAS), 地震ハザード(J-SHIS),
# GSIジオコーディング, 行政区域GeoJSON, G空間情報センター,
# NDL, J-STAGE, CiNii, ジャパンサーチ, IRDB, researchmap, AgriKnowledge,
# そらまめくん(大気汚染), 地質図(産総研), JAXA, 国会会議録,
# 官公需, パブコメ, ミラサポplus, PLATEAU, 洪水リスク, 河川水位, NDB
